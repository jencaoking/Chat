{
    "name": "chat-app/backend",
    "description": "Online Chat Website Backend API",
    "type": "project",
    "require": {
        "slim/slim": "^4.12",
        "slim/psr7": "^1.6",
        "firebase/php-jwt": "6.10.0",
        "illuminate/database": "^10.48",
        "vlucas/phpdotenv": "^5.6",
        "ext-pdo": "*"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
